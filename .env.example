# ── Ollama (local only — no external APIs, no cloud) ──────────────────────────
# Your local Ollama instance.
OLLAMA_BASE_URL=http://192.168.1.16:11435
# LLM used for classification, structured extraction, query expansion and reranking.
# qwen2.5:14b is the recommended balance. For max extraction fidelity on your GPU
# (up to ~35B Q4 fits your 24GB), use qwen2.5:32b or qwen2.5:32b-instruct-q4_K_M.
OLLAMA_LLM_MODEL=qwen2.5:14b
# Embedding model. nomic-embed-text (768-dim) is reliable and fast. Swap to
# mxbai-embed-large (1024-dim) or bge-m3 (1024-dim) for richer retrieval — the app
# auto-detects the dimension at startup, so no code change is needed.
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Qdrant (local Docker) ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledgevault

# ── Whisper (local transcription of reels/videos) ─────────────────────────────
# Set false to skip all video transcription (items with video use description only).
WHISPER_ENABLED=true
# base is fast; use small/medium for better accuracy if transcripts are weak.
WHISPER_MODEL=base
# ffmpeg is REQUIRED for audio extraction. Leave empty if ffmpeg/ffprobe are on PATH;
# otherwise set the absolute path to the ffmpeg binary directory or executable.
FFMPEG_LOCATION=

# ── Facebook video download (optional) ────────────────────────────────────────
# Path to a cookies.txt exported from your browser. Needed only for downloading
# private/saved reels. Leave empty to attempt downloads without auth (many will fail
# gracefully and the item falls back to its description).
FB_COOKIES_PATH=

# ── Storage ───────────────────────────────────────────────────────────────────
# Relative to the backend working directory (backend/). One JSON file per item.
DATA_DIR=data
MEDIA_DIR=data/media

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS origins for the extension + frontend. * is fine for local use.
CORS_ORIGINS=*

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Extractions below this confidence are flagged for human review.
EXTRACTION_CONFIDENCE_THRESHOLD=0.45
# Candidates pulled from hybrid search before LLM reranking.
RERANK_TOP_K=24
# Final results returned to the chatbot.
CHAT_TOP_N=8
# Per-index (dense / sparse) prefetch size for reciprocal-rank fusion.
HYBRID_LIMIT=40
